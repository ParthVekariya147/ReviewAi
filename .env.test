# E2E test environment — copy from .env.local and point at a dedicated TEST project.
# NEVER use your production Supabase project here.
# NEVER commit this file with real values.

# ── Supabase TEST project ─────────────────────────────────────
# Create a separate project at supabase.com for testing.
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# ── App URL (Next.js dev server started by Playwright) ────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Pre-seeded test token (set after running: npm run test:seed) ─
# The seed script prints this value after inserting the test QR code.
TEST_QR_TOKEN=

# ── AI keys (optional for E2E — generate route is mocked in tests) ─
# ANTHROPIC_API_KEY=
