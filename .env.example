# ============================================================
# Reevo AI Review SaaS — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env to git.
# Store production secrets in Vercel dashboard → Environment Variables.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── App ──────────────────────────────────────────────────────
# Full URL of this app (used in absolute links, OG images, etc.)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Google OAuth ─────────────────────────────────────────────
# Found in: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must be set to: {NEXT_PUBLIC_APP_URL}/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ── Sentry error monitoring (optional in dev, required in production) ────
# Create project at sentry.io → Settings → Projects → DSN
# Also add SENTRY_AUTH_TOKEN (for source map uploads) and SENTRY_ORG / SENTRY_PROJECT
# to your Vercel environment variables.
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# ── Supabase CLI (for schema type generation — not needed at runtime) ────
# Found in: Supabase Dashboard → Project Settings → General → Reference ID
# Used by: npm run db:types
# Add SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_ID as GitHub Actions secrets
# for CI schema drift detection.
# SUPABASE_PROJECT_ID=your-project-ref
# SUPABASE_ACCESS_TOKEN=sbp_...

# ── Upstash Redis (required for distributed rate limiting in production) ─
# Create free DB at upstash.com → copy REST URL and token
# Without these, rate limiting falls back to in-memory (dev only — not safe on Vercel)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── AI Providers (at least one required for review generation) ─
# The generator tries providers in this order: Anthropic → OpenAI → Gemini
# If none are configured, fallback static drafts are used (not recommended for production).

# Anthropic — claude.ai/api → API Keys
# Supports numbered keys for round-robin rotation: ANTHROPIC_API_KEY_1 … _9
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_1=sk-ant-...
# ANTHROPIC_API_KEY_2=sk-ant-...

# OpenAI — platform.openai.com → API Keys
# Supports numbered keys: OPENAI_API_KEY_1 … _9
OPENAI_API_KEY=sk-proj-...
# OPENAI_API_KEY_1=sk-proj-...
# OPENAI_API_KEY_2=sk-proj-...

# Google Gemini — aistudio.google.com → Get API Key
# Supports numbered keys: GEMINI_API_KEY_1 … _9
# GEMINI_API_KEY=AIzaSy...
# GEMINI_API_KEY_1=AIzaSy...
# GEMINI_API_KEY_2=AIzaSy...
